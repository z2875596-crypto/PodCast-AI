# PodCast AI — 环境变量模板
# 复制本文件为项目根目录下的 `.env`（勿将真实密钥提交到 Git）。

# --- OpenAI（Whisper 转录 API、可选用 GPT-4o-mini 摘要）---
OPENAI_API_KEY=

# --- Google Gemini（摘要生成，推荐 Gemini 1.5 Flash）---
GEMINI_API_KEY=

# --- 飞书开放平台（云文档创建 / OAuth）---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:5173/feishu/callback

# --- 后端 CORS（逗号分隔多个来源）---
BACKEND_CORS_ORIGINS=http://localhost:5173

# --- 前端（仅当以 VITE_ 前缀在构建期注入公开配置时使用；密钥勿放此处）---
# VITE_API_BASE_URL=http://127.0.0.1:8000
